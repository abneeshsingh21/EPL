Note: EPL Power Test 2: Data Structures
Note: ═══════════════════════════════════

Note: List operations
scores = [95, 87, 92, 78, 100, 88, 76, 91]

Note: Find maximum in a list
Function findMax takes items and size
    max = items[0]
    i = 1
    While i < size
        If items[i] > max then
            max = items[i]
        End
        i = i + 1
    End
    Return max
End

Note: Find minimum in a list
Function findMin takes items and size
    min = items[0]
    i = 1
    While i < size
        If items[i] < min then
            min = items[i]
        End
        i = i + 1
    End
    Return min
End

Note: Sum all elements
Function sumAll takes items and size
    total = 0
    i = 0
    While i < size
        Increase total by items[i]
        i = i + 1
    End
    Return total
End

Print "Scores:"
Print scores

Print "Max score:"
Print findMax(scores, 8)

Print "Min score:"
Print findMin(scores, 8)

Print "Total:"
Print sumAll(scores, 8)

